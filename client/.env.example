# ─── ArmVet Admin Frontend — Environment Variables ───────────────────────────
#
# Copy this file to .env (for local dev) or configure these as Render env vars.
#
# The Cloudflare Worker URL for the API.
# Leave empty in local dev — the Vite proxy handles /api → localhost:8787.
# In production, set this to your deployed Worker URL, e.g.:
#   https://armvet-api.<your-account>.workers.dev
VITE_API_URL=

# Override the local Wrangler dev server port if you changed it in wrangler.toml
# VITE_DEV_API_URL=http://localhost:8787
